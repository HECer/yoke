    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HECer/yoke.git"
  },
  "homepage": "https://github.com/HECer/yoke#readme",
  "bugs": {
    "url": "https://github.com/HECer/yoke/issues"
  },
  "keywords": [
    "claude-code",
    "codex",
    "gemini-cli",
    "agents",
    "agentic-coding",
    "harness",
